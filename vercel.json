{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/measure.mjs": { "maxDuration": 60, "memory": 1024 },
    "api/analyze.mjs": { "maxDuration": 15, "memory": 512 },
    "api/bench.mjs": { "maxDuration": 5, "memory": 256 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
